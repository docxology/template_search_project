# template_search_project — environment variables
#
# Copy this file to `.env` (gitignored) and fill in your real values.
# Loaded by:
#   - scripts/run_deep_search.py and scripts/run_search_pipeline.py
#     when sources include `paperclip`.
#
# Paperclip API key (https://gxl.ai). Required only when the configured
# search.sources or deep_search.sources includes "paperclip". Without
# this, all other backends (arxiv, crossref, local) still work.
PAPERCLIP_API_KEY=

# Crossref polite-pool identifier. Optional but recommended for live runs;
# Crossref grants higher rate limits when you identify yourself.
CROSSREF_MAILTO=you@example.org

# Override Paperclip base URL if the production endpoint moves.
# Default in PaperclipBackend: https://paperclip.gxl.ai/papers
# PAPERCLIP_BASE_URL=https://paperclip.gxl.ai/papers
