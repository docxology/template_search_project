@article{abubaker2022scaling,
  title={Scaling Stratified Stochastic Gradient Descent for Distributed Matrix Completion},
  author={Nabil Abubaker and M. Ozan Karsavuran and Cevdet Aykanat},
  year={2022},
  publisher={Institute of Electrical and Electronics Engineers (IEEE)},
  doi={10.36227/techrxiv.19350536.v1},
  abstract={Stratified SGD (SSGD) is the primary approach for achieving serializable
parallel SGD for matrix completion. State-of-the-art parallelizations of
SSGD fail to scale due to huge communication overhead. During an SGD
epoch, these methods send data proportional to one of the dimensions of
the rating matrix. We propose a framework for scalable SSGD through
significantly reducing the communication overhead via exchanging
point-to-point messages utilizing the sparsity of the input matrix. We
provide formulas to represent the essential communication for correctly
performing parallel SSGD and we propose a dynamic programming algorithm
for efficiently computing them to establish the point-to-point message
schedules. This scheme, however, significantly increases the number of
messages sent by a processor per epoch from O(K) to O(K\textasciicircum{}2) for a
K-processor system which might limit the scalability. To remedy this, we
propose a Hold-and-Combine strategy to limit the upper-bound on the
number of messages sent per processor to O(KlgK). We also propose a
hypergraph partitioning model that correctly encapsulates reducing the
communication volume. Experimental results show that the framework
successfully achieves a scalable distributed SSGD through significantly
reducing the communication overhead. Our code is publicly available at:
github.com/nfabubaker/CESSGD}
}

@article{fu2025theoretical,
  title={A Theoretical and Experimental Study of Gradient Descent and Its Stochastic Variants},
  author={Jiwei Fu and Mohammud Foondun},
  year={2025},
  publisher={Institute of Electrical and Electronics Engineers (IEEE)},
  doi={10.36227/techrxiv.176162233.33076025/v1},
  abstract={Stochastic Gradient Descent (SGD) is an influential optimization technique widely used in the fields of machine learning and deep learning. This paper introduces the concept of Gradient Descent (GD), SGD, and Mini-Batch SGD with a specific focus on the comparison between these three similar algorithms via code implementations in large-sample regression analysis. The results show that Gradient Descent ensures comprehensive, albeit slow, progress. Stochastic Gradient Descent leads to the quickest convergence rate, albeit with high variability. Mini-batch Gradient Descent achieves a trade-off between computational efficiency and algorithmic stability. Our study provides a comprehensive analysis of many essential optimization approaches, highlighting their practical use and associated trade-offs. This research offers valuable theoretical comprehension for beginners.}
}

@article{abubaker2022scalinga,
  title={Scaling Stratified Stochastic Gradient Descent for Distributed Matrix Completion},
  author={Nabil Abubaker and M. Ozan Karsavuran and Cevdet Aykanat},
  year={2022},
  publisher={Institute of Electrical and Electronics Engineers (IEEE)},
  doi={10.36227/techrxiv.19350536},
  abstract={\&lt;p\&gt;Stratified SGD (SSGD) is the primary approach for achieving serializable parallel SGD for matrix completion. State-of-the-art parallelizations of SSGD fail to scale due to huge communication overhead. During an SGD epoch, these methods send data proportional to one of the dimensions of the rating matrix. We propose a framework for scalable SSGD through significantly reducing the communication overhead via exchanging point-to-point messages utilizing the sparsity of the input matrix. We provide formulas to represent the essential communication for correctly performing parallel SSGD and we propose a dynamic programming algorithm for efficiently computing them to establish the point-to-point message schedules. This scheme, however, significantly increases the number of messages sent by a processor per epoch from O(K) to O(K\textasciicircum{}2) for a K-processor system which might limit the scalability. To remedy this, we propose a Hold-and-Combine strategy to limit the upper-bound on the number of messages sent per processor to O(KlgK). We also propose a hypergraph partitioning model that correctly encapsulates reducing the communication volume. Experimental results show that the framework successfully achieves a scalable distributed SSGD through significantly reducing the communication overhead. Our code is publicly available at: github.com/nfabubaker/CESSGD\&lt;/p\&gt;\&lt;div\&gt;\&lt;br\&gt;\&lt;/div\&gt;}
}

