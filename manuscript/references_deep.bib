@article{abrolbekov2026high,
  title={High Probability Convergence Bounds for Non-convex Stochastic Gradient Descent with Sub-Weibull Noise},
  author={Makhamadamin Abrolbekov},
  year={2026},
  publisher={Elsevier BV},
  doi={10.2139/ssrn.6738058},
  abstract={This research investigates the convergence properties of the Stochastic Gradient Descent (SGD) algorithm within the context of complex non-convex optimization problems. Unlike the majority of existing theoretical approaches that focus solely on establishing convergence in mathematical expectation, this study is dedicated to establishing strict convergence bounds with high probability. The practical significance of these results is demonstrated through their direct applicability to stabilizing the training of massive neural network architectures, including Large Language Models (LLMs) and transformers, which frequently encounter chaotic, heavy-tailed gradient noise. The investigation systematically examines two distinct theoretical scenarios: objective functions that satisfy the Polyak-Lojasiewicz condition under sub-Gaussian noise, and general smooth non-convex functions subjected to gradient noise modeled by a sub-Weibull distribution. The primary scientific contribution of this research is the derivation of an adapted concentration inequality designed for martingale difference sequences with heavy tails. Furthermore, this study presents a resource-efficient post-processing methodology to select the optimal model state from the optimization process. By removing the reliance on average-case analysis, this work provides robust theoretical guarantees that align with the practical realities of deploying modern machine learning algorithms\&amp;nbsp;}
}

