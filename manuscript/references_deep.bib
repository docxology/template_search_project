@article{kunisato2019introduction,
  title={Introduction to reproducible psychological research},
  author={Yoshihiko Kunisato},
  year={2019},
  publisher={Center for Open Science},
  doi={10.31234/osf.io/x8js5},
  abstract={This paper is written by Japanese. In this paper, we reviewed the reproducibility crisis in psychology and discussed the definition of reproducibility. Starting from the distinction between reproducibility and replicability by Claerbout-Donoho-Peng, the concept of three reproducibilities (method, result, reasoning) by Goodman et al. (2016) was introduced. Many efforts to increase reproducibility have started in recent years, and it is difficult to understand how individual efforts are located in what kind of reproducibility. Therefore, based on the three reproducibilities of Goodman et al. (2016), we explained the factors that reduce reproducibility and the measures to increase it so that the whole image of reproducibility can be captured. Finally, as an effort to increase the method reproducibility, data management for sharing, packaging of analysis, and containerization of the analysis environment were explained concretely. Methods to improve reproducibility have not been addressed in psychological education, and I hope that this paper will help in reproducible psychological research practices.}
}

