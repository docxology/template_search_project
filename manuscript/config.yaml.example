# template_search_project — configuration TEMPLATE
#
# Copy this file to `config.yaml` and customize for your literature-search
# project. The bundled `config.yaml` ships with a real, descriptive title and
# offline/CI-safe defaults (local corpus only) so the exemplar renders
# deterministically with no network. This example shows the placeholder
# fields you should replace when forking the project for your own manuscript.
#
# Release workflow (Zenodo + GitHub): see docs/guides/publishing-guide.md and
# docs/guides/zenodo-doi-strategy.md for the split concept/version DOI layout.

paper:
  title: "Your Manuscript Title"
  subtitle: "Optional Subtitle"
  version: "1.0"   # Zenodo version field; GitHub release body version line
  # date: "2026-05-27"  # Optional; Zenodo publication_date (overrides publication.year)

authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"   # Zenodo creator ORCID — placeholder values are omitted at deposit
    email: "you@example.org"
    affiliation: "Your Institution"
    corresponding: true

publication:
  doi: ""
  journal: ""
  year: "2026"
  github_repository: "your-org/your-repo"

keywords:
  - "literature search"
  - "automated reference management"
  - "BibTeX"
  - "reproducible research"
  - "local LLM synthesis"

metadata:
  license: "MIT"
  language: "en"

# ---------------------------------------------------------------------------
# LLM synthesis (Ollama-local). Default OFF so the pipeline runs in CI
# without an Ollama server. Flip to `true` and start `ollama serve` to use.
# ---------------------------------------------------------------------------
llm:
  enabled: false
  model: "gemma3:4b"
  temperature: 0.0
  seed: 42
  per_paper: true
  corpus_synthesis: true
  output_dir: "output/llm"
  # Ollama budgets (optional; defaults match prior orchestrator literals).
  # Env: LLM_CONTEXT_WINDOW, LLM_LONG_MAX_TOKENS, LLM_MAX_INPUT_LENGTH,
  # LLM_REVIEW_TIMEOUT still affect other clients via from_env(); these YAML
  # values are what run_search_pipeline passes explicitly.
  context_window: 131072
  long_max_tokens: 16384
  max_input_length: 600000
  review_timeout: 600.0

# ---------------------------------------------------------------------------
# Final report
# ---------------------------------------------------------------------------
report:
  output_path: "output/reading_report.md"
  include_per_paper: true
  include_corpus_synthesis: true

project_config:
  search:
    query: "your topic here"
    max_results: 100
    year_min: null
    year_max: null
    sources:
      - "local"
    local_corpus: "data/corpus.json"
    crossref_mailto: "you@example.org"
    paperclip: false
    cache_dir: "output/search/cache"
    cache_ttl_seconds: null

  enrichment:
    fetch_abstracts: true
    fetch_fulltext: false
    abstract_cache_dir: "output/cache/abs"
    fulltext_cache_dir: "output/cache/pdf"
    max_fulltext_chars: 400000

  references_path: "manuscript/references.bib"

  deep_search:
    enabled: false
    keywords:
      - "your first keyword"
      - "your second keyword"
    max_results_per_keyword: 100
    sources:
      - "arxiv"
      - "crossref"
    year_min: null
    year_max: null
    crossref_mailto: "you@example.org"
    fetch_abstracts: true
    fetch_fulltext: true
    max_fulltext_chars: 400000
    llm_per_paper: true
    llm_model: "gemma3:4b"
    llm_seed: 42
    llm_temperature: 0.0
    output_dir: "output/deep_search"
    abstract_cache_dir: "output/cache/abs"
    fulltext_cache_dir: "output/cache/pdf"
    search_cache_dir: "output/search/cache"
    write_unified_bibtex: true
    unified_bibtex_path: "manuscript/references_deep.bib"
